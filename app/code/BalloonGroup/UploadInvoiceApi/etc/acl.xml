<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Sales::sales">
                    <resource id="Magento_Sales::sales_operation">
                        <resource id="BalloonGroup_UploadInvoiceApi::main"
                                  title="Administrar Facturas"
                                  sortOrder="900">
                            <resource id="BalloonGroup_UploadInvoiceApi::upload_invoice"
                                      title="Facturas No Relacionadas a Pedido"
                                      sortOrder="10">
                                <resource id="BalloonGroup_UploadInvoiceApi::upload_invoice_view"
                                          title="View Invoice"
                                          sortOrder="10"/>
                                <resource id="BalloonGroup_UploadInvoiceApi::upload_invoice_save"
                                          title="Save Invoice"
                                          sortOrder="20"/>
                                <resource id="BalloonGroup_UploadInvoiceApi::upload_invoice_update"
                                          title="Update Invoice"
                                          sortOrder="30"/>
                                <resource id="BalloonGroup_UploadInvoiceApi::upload_invoice_delete"
                                          title="Delete Invoice"
                                          sortOrder="40"/>
                            </resource>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
