<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Magento\Customer\Model\GroupManagement" type="BalloonGroup\Customer\Model\GroupManagement"/>
    <preference for="Magento\Customer\Block\Adminhtml\Group\Edit\Form" type="BalloonGroup\Customer\Block\Adminhtml\Group\Edit\Form"/>
    <preference for="Magento\Customer\Model\Group" type="BalloonGroup\Customer\Model\Group"/>
    <preference for="Magento\Customer\Model\ResourceModel\Group" type="BalloonGroup\Customer\Model\ResourceModel\Group"/>

    <!-- To send customer password on welcome email after registration -->
    <type name="Magento\Customer\Model\AccountManagement">
        <plugin name="BalloonGroup_Customer::PasswordEmail" type="BalloonGroup\Customer\Plugin\AccountManagementPlugin" />
    </type>
    <type name="Magento\Customer\Model\EmailNotification">
        <plugin name="BalloonGroup_Customer::UnsetWelcomeEmail" type="BalloonGroup\Customer\Plugin\EmailNotificationPlugin" />
    </type>

    <type name="Magento\Directory\Model\Currency">
        <plugin name="BalloonGroup_Customer::FixCurrency" type="BalloonGroup\Customer\Plugin\FixCurrencyPlugin" />
    </type>
    <type name="Magento\Framework\Mail\Template\TransportBuilder">
        <plugin name="BalloonGroup_Customer::OverrideRecipient"
                type="BalloonGroup\Customer\Plugin\TransportBuilderPlugin"/>
    </type>
</config>
