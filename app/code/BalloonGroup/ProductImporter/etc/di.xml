<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="BalloonGroup\ProductImporter\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="BalloonGroup\ProductImporter\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">productImporter</argument>
            <argument name="handlers"  xsi:type="array">
                <item name="system" xsi:type="object">BalloonGroup\ProductImporter\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\ImportExport\Model\Import\SampleFileProvider">
        <arguments>
            <argument name="samples" xsi:type="array">
                <item name="dimagraf_products" xsi:type="string">BalloonGroup_ProductImporter</item>
            </argument>
        </arguments>
    </type>
</config>
