<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order" resource="default" engine="innodb" comment="Sales Order">
        <column xsi:type="varchar" length="255" name="sap_invoice" nullable="true" default="" comment="SAP Invoice id"/>
        <column xsi:type="varchar" length="255" name="sap_invoice_file" nullable="true" default="" comment="SAP Invoice PDF path"/>
    </table>
    <table name="sales_order_grid" resource="default" engine="innodb" comment="Sales Order Grid">
        <column xsi:type="varchar" length="255" name="sap_invoice" nullable="true" default="" comment="SAP Invoice id"/>
        <column xsi:type="varchar" length="255" name="sap_invoice_file" nullable="true" default="" comment="SAP Invoice PDF path"/>
    </table>
</schema>
