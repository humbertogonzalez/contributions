<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/amcompany/search" method="GET">
        <service class="BalloonGroup\Company\Api\CompanyRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Amasty_CompanyAccount::company_management"/>
        </resources>
    </route>
    <route url="/V1/amcompany/createSalesUser" method="POST">
        <service class="BalloonGroup\Company\Api\SalesUserInterface" method="save"/>
        <resources>
            <resource ref="Amasty_CompanyAccount::company_management"/>
        </resources>
    </route>
    <route url="/V1/amcompany/updateSalesUser" method="PUT">
        <service class="BalloonGroup\Company\Api\SalesUserInterface" method="save"/>
        <resources>
            <resource ref="Amasty_CompanyAccount::company_management"/>
        </resources>
    </route>
    <route url="/V1/amcompany/salesUser/:userId" method="GET">
        <service class="BalloonGroup\Company\Api\SalesUserInterface" method="getById"/>
        <resources>
            <resource ref="Amasty_CompanyAccount::company_management" />
        </resources>
    </route>
    <route url="/V1/salesUser/search" method="GET">
        <service class="BalloonGroup\Company\Api\SalesUserInterface" method="getList"/>
        <resources>
            <resource ref="Amasty_CompanyAccount::company_management"/>
        </resources>
    </route>
</routes>
